# LLM API Keys
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key
# Anthropic: https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=your-api-key
# Google AI Studio: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-api-key
# xAI: https://console.x.ai/
XAI_API_KEY=your-api-key
# OpenRouter: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your-api-key
# Moonshot: https://platform.moonshot.ai/console/api-keys
MOONSHOT_API_KEY=your-api-key
# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-api-key

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Stock Market API Key
# Financial Datasets: https://financialdatasets.ai/
FINANCIAL_DATASETS_API_KEY=your-api-key
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your-api-key

# Web Search API Keys (Auto mode prefers Exa, then LangSearch, then Tavily)
# Exa: https://dashboard.exa.ai/
EXASEARCH_API_KEY=your-api-key
# LangSearch: https://langsearch.com/dashboard
LANGSEARCH_API_KEY=your-api-key
# Tavily: https://app.tavily.com/home
TAVILY_API_KEY=your-api-key

# LangSmith 
LANGSMITH_API_KEY=your-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=dexter
LANGSMITH_TRACING=true
